# Brandwatch API credentials
# Ottieni le credenziali da: https://developers.brandwatch.com/docs/authentication
# Nella console Brandwatch: Settings → API Access

# Client ID dell'applicazione API Brandwatch
BW_CLIENT_ID=your_client_id_here

# Client Secret (se richiesto dal tuo piano)
BW_CLIENT_SECRET=your_client_secret_here

# Email di accesso al tuo account Brandwatch
BW_USERNAME=your_brandwatch_email@example.com

# Password del tuo account Brandwatch
BW_PASSWORD=your_brandwatch_password

# ID numerico del progetto Brandwatch
# Trovalo in: https://app.brandwatch.com/ → seleziona progetto → URL contiene /projects/XXXXXXX
BW_PROJECT_ID=123456789

# ── Server config ────────────────────────────────────────────────────
PORT=3001

# Origine consentita per CORS (dove gira index.html)
CORS_ORIGIN=http://localhost:8080
